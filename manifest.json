{
  "manifest_version": 3,
  "name": "InContext — 划词释义（基于全文理解）",
  "version": "0.1.0",
  "description": "划选网页中的任意一段，基于大模型对整篇文章的理解给出解释，并可就这段多轮追问。Explain any selection — grounded in the whole page, not just the snippet.",
  "default_locale": "zh_CN",
  "permissions": ["activeTab", "scripting", "storage", "sidePanel", "contextMenus"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["vendor/Readability.js", "src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "src/sidepanel.html"
  },
  "options_page": "src/options.html",
  "action": {
    "default_title": "InContext 划词释义"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "explain-selection": {
      "suggested_key": { "default": "Ctrl+Shift+E", "mac": "Command+Shift+E" },
      "description": "解释当前选中的文本"
    }
  }
}
